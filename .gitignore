# ═══════════════════════════════════════════════════
#  AetherGrid — .gitignore
# ═══════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
ENV/
env/

# Jupyter
.ipynb_checkpoints/

# ── Node / Frontend ───────────────────────────────
node_modules/
frontend/node_modules/
.npm-cache/
.npm-cache2/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite build output
frontend/dist/
dist/

# ── IDE / Editor ──────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment / Secrets ─────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Agent / Planning (GSD tooling) ────────────────
.planning/
.agent/
.claude/

# ── Stitch design mockups (reference only) ────────
landing_stitch.html
dashboard_stitch.html

# ── Misc ──────────────────────────────────────────
*.log
*.pid
*.seed
coverage/
.cache/
